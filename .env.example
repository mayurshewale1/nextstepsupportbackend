# Database (PostgreSQL - Neon or local)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Server
PORT=5000
NODE_ENV=development

# JWT (use a strong secret in production)
JWT_SECRET=your_secret_key_here
JWT_EXPIRE=7d

# CORS (comma-separated for multiple origins)
# Add all origins where your web app will run (localhost, production URL, etc.)
CORS_ORIGIN=http://localhost:3000,http://localhost:5000,https://nextstep.mayurr.in,http://127.0.0.1:3000,http://127.0.0.1:5000

# API
API_VERSION=v1
